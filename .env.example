# === LLM Provider 配置 ===
# 方式1：使用 GLM-4.7-Flash（免费，推荐）
# 注册地址：https://open.bigmodel.cn/
# LLM_API_KEY=your-glm-api-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4.7-flash

# 方式2：使用 DeepSeek-V3（付费，约¥5-10/次完整评测）
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 方式3：使用 Qwen 通义千问（有免费额度）
# LLM_API_KEY=sk-your-dashscope-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 兼容旧变量名（LLM_* 优先于 DEEPSEEK_*）
# DEEPSEEK_API_KEY=sk-your-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === 多模态附件后端（可选，GAIA 图片/音频/视频题用）===
# 任意 OpenAI 兼容的视觉/转写端点；不配置则 GAIA 多模态附件题优雅降级为跳过（保持原跑分）
# PEC_VISION_BASE_URL=https://api.openai.com/v1
# PEC_VISION_MODEL=gpt-4o-mini
# PEC_VISION_API_KEY=sk-your-vision-key
# PEC_TRANSCRIBE_MODEL=gpt-4o-mini   # 音频转写模型（默认同 PEC_VISION_MODEL；部分端点支持 audio transcription）

# === 真实搜索 API（可选，提升 Web 接地质量）===
# PEC_SEARCH_PROVIDER=tavily
# PEC_SEARCH_API_KEY=your-tavily-key

# === LangChain 追踪（可选）===
LANGCHAIN_API_KEY=your-key-here
LANGCHAIN_TRACING_V2=false
